{
  "name": "bids-mriqc-assessor",
  "description": "Runs MRIQC and creates an assessor with extracted metadata",
  "version": "1.3",
  "schema-version": "1.0",
  "image": "nipreps/mriqc:24.0.2",
  "type": "docker",
  "command-line": "mriqc /input /output participant --no-sub --nprocs 1 --omp-nthreads 1 --mem_gb 28 -v #FLAGS#",
  "override-entrypoint": true,
  "mounts": [
    {
      "name": "in",
      "writable": false,
      "path": "/input"
    },
    {
      "name": "out",
      "writable": true,
      "path": "/output"
    }
  ],
  "environment-variables": {
    "PROJECT": "#PROJECT#",
    "SESSION_LABEL": "#SESSION_LABEL#",
    "SESSION_ID": "#SESSION_ID#"
  },
  "ports": {},
  "inputs": [
    {
      "name": "SESSION_ID",
      "type": "string",
      "required": true,
      "select-values": []
    },
    {
      "name": "SESSION_LABEL",
      "type": "string",
      "required": true,
      "select-values": []
    },
    {
      "name": "PROJECT",
      "type": "string",
      "required": true,
      "select-values": []
    },
    {
      "name": "flags",
      "label": "MRIQC flags",
      "description": "Flags to pass to MRIQC",
      "type": "string",
      "default-value": "",
      "required": false,
      "replacement-key": "#FLAGS#",
      "sensitive": false,
      "select-values": []
    }
  ],
  "outputs": [
    {
      "name": "output",
      "description": "Output QC files",
      "required": true,
      "mount": "out"
    }
  ],
  "xnat": [
    {
      "name": "bids-mriqc-session-assessor",
      "description": "Run MRIQC and create assessor with results",
      "contexts": [
        "xnat:imageSessionData"
      ],
      "external-inputs": [
        {
          "name": "session",
          "description": "Input session",
          "type": "Session",
          "required": true,
          "provides-files-for-command-mount": "in",
          "via-setup-command": "xnatworks/xnat2bids-setup:1.7:xnat2bids",
          "load-children": false
        }
      ],
      "derived-inputs": [
        {
          "name": "session-id",
          "type": "string",
          "required": true,
          "provides-value-for-command-input": "SESSION_ID",
          "user-settable": false,
          "load-children": true,
          "derived-from-wrapper-input": "session",
          "derived-from-xnat-object-property": "id",
          "multiple": false
        },
        {
          "name": "session-label",
          "type": "string",
          "required": true,
          "provides-value-for-command-input": "SESSION_LABEL",
          "user-settable": false,
          "load-children": true,
          "derived-from-wrapper-input": "session",
          "derived-from-xnat-object-property": "label",
          "multiple": false
        },
        {
          "name": "project-id",
          "type": "string",
          "required": true,
          "provides-value-for-command-input": "PROJECT",
          "user-settable": false,
          "load-children": true,
          "derived-from-wrapper-input": "session",
          "derived-from-xnat-object-property": "project-id",
          "multiple": false
        }
      ],
      "output-handlers": [
        {
          "name": "assessor",
          "accepts-command-output": "output",
          "via-wrapup-command": "xnatworks/bids-assessor-wrapup:2.5:bids-assessor-wrapup",
          "as-a-child-of": "session",
          "type": "Assessor",
          "tags": []
        },
        {
          "name": "data-resource",
          "accepts-command-output": "output",
          "as-a-child-of": "assessor",
          "type": "Resource",
          "label": "DATA",
          "tags": []
        }
      ]
    }
  ],
  "reserve-memory": 28360,
  "limit-cpu": 4,
  "container-labels": {},
  "generic-resources": {},
  "ulimits": {},
  "secrets": [],
  "visibility": "public"
}
