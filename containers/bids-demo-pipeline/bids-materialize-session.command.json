{
  "name": "bids-materialize",
  "description": "Materialize the BIDS layout for a session. Runs the xnat2bids setup to assemble BIDS structure from scan-level NIFTI/BIDS resources, then saves the result as a session-level resource.",
  "version": "1.0",
  "schema-version": "1.0",
  "image": "busybox:1.37.0",
  "type": "docker",
  "command-line": "cp -r /input/. /output/",
  "override-entrypoint": true,
  "mounts": [
    {
      "name": "in",
      "writable": false,
      "path": "/input"
    },
    {
      "name": "out",
      "writable": true,
      "path": "/output"
    }
  ],
  "inputs": [],
  "outputs": [
    {
      "name": "output",
      "description": "Materialized BIDS dataset",
      "required": true,
      "mount": "out"
    }
  ],
  "xnat": [
    {
      "name": "bids-materialize-session",
      "description": "Materialize BIDS layout for a session",
      "contexts": [
        "xnat:imageSessionData"
      ],
      "external-inputs": [
        {
          "name": "session",
          "description": "Input session",
          "type": "Session",
          "required": true,
          "provides-files-for-command-mount": "in",
          "via-setup-command": "xnatworks/xnat2bids-setup:1.7:xnat2bids",
          "load-children": false
        }
      ],
      "derived-inputs": [],
      "output-handlers": [
        {
          "name": "output-resource",
          "accepts-command-output": "output",
          "as-a-child-of": "session",
          "type": "Resource",
          "label": "BIDS"
        }
      ]
    }
  ]
}
